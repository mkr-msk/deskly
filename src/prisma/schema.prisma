generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  AGENT
  ADMIN
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         Role     @default(USER)
  createdAt    DateTime @default(now())
  
  tickets      Ticket[]
}

model Ticket {
  id          String   @id @default(cuid())
  title       String
  description String
  authorId    String
  createdAt   DateTime @default(now())

  author      User     @relation(fields: [authorId], references: [id])
}